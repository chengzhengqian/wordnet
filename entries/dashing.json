{"word": "dashing", "meanings": [{"pos": "v", "definition": "run or move very quickly or hastily", "synonyms": ["dart", "dash", "scoot", "scud", "flash", "shoot"], "examples": ["She dashed into the yard"]}, {"pos": "v", "definition": "break into pieces, as by striking or knocking over", "synonyms": ["smash", "dash"], "examples": ["Smash a plate"]}, {"pos": "v", "definition": "hurl or thrust violently", "synonyms": ["crash", "dash"], "examples": ["He dashed the plate against the wall", "Waves were dashing against the rock"]}, {"pos": "v", "definition": "destroy or break", "synonyms": ["dash"], "examples": ["dashed ambitions and hopes"]}, {"pos": "v", "definition": "cause to lose courage", "synonyms": ["daunt", "dash", "scare off", "pall", "frighten off", "scare away", "frighten away", "scare"], "examples": ["dashed by the refusal"]}, {"pos": "v", "definition": "add an enlivening or altering element to", "synonyms": ["dash"], "examples": ["blue paint dashed with white"]}, {"pos": "s", "definition": "lively and spirited", "synonyms": ["gallant"], "examples": ["a dashing hero"]}, {"pos": "s", "definition": "marked by up-to-dateness in dress and manners", "synonyms": ["dapper", "jaunty", "natty", "raffish", "rakish", "spiffy", "snappy", "spruce"], "examples": ["a dapper young man", "a jaunty red hat"]}]}
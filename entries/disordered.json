{"word": "disordered", "meanings": [{"pos": "v", "definition": "disturb in mind or make uneasy or cause to be worried or alarmed", "synonyms": ["perturb", "unhinge", "disquiet", "trouble", "cark", "distract", "disorder"], "examples": ["She was rather perturbed by the news that her father was seriously ill"]}, {"pos": "v", "definition": "bring disorder to", "synonyms": ["disorder", "disarray"], "examples": []}, {"pos": "s", "definition": "thrown into a state of disarray or confusion", "synonyms": ["broken", "confused", "upset"], "examples": ["troops fleeing in broken ranks", "a confused mass of papers on the desk", "the small disordered room", "with everything so upset"]}, {"pos": "s", "definition": "lacking orderly continuity", "synonyms": ["confused", "disconnected", "disjointed", "garbled", "illogical", "scattered", "unconnected"], "examples": ["a confused set of instructions", "a confused dream about the end of the world", "disconnected fragments of a story", "scattered thoughts"]}, {"pos": "a", "definition": "not arranged in order", "synonyms": ["unordered"], "examples": []}]}
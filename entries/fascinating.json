{"word": "fascinating", "meanings": [{"pos": "v", "definition": "cause to be interested or curious", "synonyms": ["intrigue", "fascinate"], "examples": []}, {"pos": "v", "definition": "to render motionless, as with a fixed stare or by arousing terror or awe", "synonyms": ["fascinate", "transfix", "grip", "spellbind"], "examples": ["The snake charmer fascinates the cobra"]}, {"pos": "v", "definition": "attract; cause to be enamored", "synonyms": ["capture", "enamour", "trance", "catch", "becharm", "enamor", "captivate", "beguile", "charm", "fascinate", "bewitch", "entrance", "enchant"], "examples": ["She captured all the men's hearts"]}, {"pos": "s", "definition": "capable of arousing and holding the attention", "synonyms": ["absorbing", "engrossing", "gripping", "riveting"], "examples": ["a fascinating story"]}, {"pos": "s", "definition": "capturing interest as if by a spell", "synonyms": ["bewitching", "captivating", "enchanting", "enthralling", "entrancing"], "examples": ["bewitching smile", "Roosevelt was a captivating speaker", "enchanting music", "an enthralling book", "antique papers of entrancing design", "a fascinating woman"]}]}